{
	"manifest_version": 3,
	"name": "Taskbar Chrome Extension",
	"version": "1.0.0",
	"description": "A Chrome extension built with Vite and React",
	"action": {
		"default_popup": "index.html"
	},
	"host_permissions": [
		"http://*/*",
    "https://*/*"
	],
	"background": {
		"service_worker": "src/background/index.ts", 
		"type": "module"
	},
	
	"permissions": ["tabs"]
}